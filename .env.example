# Neon Postgres connection string (use the -pooler host for serverless deploys)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Azure OpenAI — OpenAI-compatible v1 endpoint of your Azure AI resource.
# Leave AZURE_OPENAI_API_KEY empty to run with the built-in mock extractor (no AI calls).
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# Admin auth (only the admin can upload receipts; public can browse/compare)
ADMIN_PASSWORD=choose-a-strong-password
# 32+ random bytes, e.g. `openssl rand -hex 32`
AUTH_SECRET=
